.sandbox-container {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.canvas-area {
  flex: 1;
  position: relative;
  background: #FFFFFF;
  overflow: hidden;
}

.main-canvas {
  display: block;
}

.guide-lines {
  position: absolute;
  top: 0;
  left: 0;
  pointer-events: none;
}

.guide-line {
  position: absolute;
  background: rgba(33, 150, 243, 0.3);
}

.guide-line.vertical {
  width: 2rpx;
  height: 100%;
}

.guide-line.horizontal {
  width: 100%;
  height: 2rpx;
}

.guide-dot {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #2196F3;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.toolbar {
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tool-group {
  display: flex;
  gap: 20rpx;
}

.tool-item {
  width: 80rpx;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon {
  font-size: 36rpx;
}

.action-group {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
}

.action-btn.primary .action-text {
  color: #FFFFFF;
}

.action-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #757575;
}

.color-panel, .analysis-panel, .chat-panel {
  position: fixed;
  bottom: 180rpx;
  left: 30rpx;
  right: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  max-height: 70vh;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #757575;
  font-size: 28rpx;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 20rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
}

.color-item:active {
  border-color: #2196F3;
}

.opacity-slider {
  padding: 20rpx 24rpx 24rpx;
}

.slider-label {
  font-size: 24rpx;
  color: #757575;
  display: block;
  margin-bottom: 12rpx;
}

.analysis-content {
  padding: 24rpx;
}

.analysis-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2196F3;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #757575;
}

.analysis-text {
  font-size: 28rpx;
  color: #212121;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.analysis-suggestions {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestions-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #212121;
  display: block;
  margin-bottom: 12rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: #757575;
  margin-bottom: 8rpx;
}

.chat-messages {
  padding: 20rpx;
  max-height: 400rpx;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-left: 12rpx;
  font-size: 26rpx;
  color: #212121;
}

.chat-input {
  display: flex;
  padding: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #2196F3;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.ai-message-toast {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.8);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  z-index: 200;
}

.ai-avatar {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.ai-text {
  color: #FFFFFF;
  font-size: 28rpx;
  max-width: 500rpx;
}