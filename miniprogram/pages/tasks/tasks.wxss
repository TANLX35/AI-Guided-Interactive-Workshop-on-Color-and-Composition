.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #212121;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #757575;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  background: #FFFFFF;
  padding: 12rpx;
  border-radius: 12rpx;
}

.filter-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 8rpx;
  position: relative;
}

.filter-item.active {
  background: #E3F2FD;
}

.filter-text {
  font-size: 26rpx;
  color: #757575;
}

.filter-item.active .filter-text {
  color: #2196F3;
  font-weight: 600;
}

.filter-active {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #2196F3;
  border-radius: 2rpx;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.difficulty-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.difficulty-badge[data-difficulty="easy"] {
  background: #E8F5E9;
  color: #4CAF50;
}

.difficulty-badge[data-difficulty="medium"] {
  background: #FFF3E0;
  color: #FF9800;
}

.difficulty-badge[data-difficulty="hard"] {
  background: #FFEBEE;
  color: #F44336;
}

.progress-indicator {
  font-size: 24rpx;
  color: #2196F3;
  font-weight: 600;
}

.task-content {
  margin-bottom: 20rpx;
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #212121;
  display: block;
  margin-bottom: 12rpx;
}

.task-desc {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.5;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.task-hints {
  display: flex;
  align-items: center;
}

.hints-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.hints-count {
  font-size: 24rpx;
  color: #757575;
}

.task-action {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 26rpx;
  color: #2196F3;
  margin-right: 8rpx;
}

.action-arrow {
  font-size: 28rpx;
  color: #2196F3;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #212121;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #757575;
}