.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.task-detail {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.difficulty-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.difficulty-badge[data-difficulty="easy"] {
  background: #E8F5E9;
  color: #4CAF50;
}

.difficulty-badge[data-difficulty="medium"] {
  background: #FFF3E0;
  color: #FF9800;
}

.difficulty-badge[data-difficulty="hard"] {
  background: #FFEBEE;
  color: #F44336;
}

.completed-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #E8F5E9;
  color: #4CAF50;
}

.task-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #212121;
  display: block;
  margin-bottom: 16rpx;
}

.task-description {
  font-size: 28rpx;
  color: #757575;
  line-height: 1.6;
  display: block;
  margin-bottom: 40rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
  display: block;
  margin-bottom: 20rpx;
}

.requirements-list {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx;
}

.requirement-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.requirement-icon {
  color: #4CAF50;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.requirement-text {
  font-size: 26rpx;
  color: #212121;
}

.hints-list {
  background: #FFF9E6;
  border-radius: 16rpx;
  padding: 20rpx;
}

.hint-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #FFECB3;
}

.hint-item:last-child {
  border-bottom: none;
}

.hint-number {
  width: 36rpx;
  height: 36rpx;
  background: #FF9800;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.hint-text {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.5;
}

.progress-section {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-bar {
  height: 16rpx;
  background: #E0E0E0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2196F3 0%, #1976D2 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2196F3;
  text-align: right;
  display: block;
}

.score-card {
  background: #F3E5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.score-circle {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.score-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-feedback {
  flex: 1;
}

.feedback-text {
  font-size: 28rpx;
  color: #5D4037;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-secondary {
  flex: 1;
  padding: 28rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  text-align: center;
}

.btn-secondary text {
  font-size: 30rpx;
  color: #757575;
  font-weight: 500;
}

.btn-primary {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  border-radius: 16rpx;
  text-align: center;
}

.btn-primary text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #757575;
}