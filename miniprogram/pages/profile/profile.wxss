.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2196F3;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #757575;
}

.stat-divider {
  width: 2rpx;
  background: #F0F0F0;
}

.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
  display: block;
  margin-bottom: 20rpx;
}

.works-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.work-item {
  width: calc(33.33% - 14rpx);
}

.work-thumb {
  width: 150rpx;
  height: 150rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.work-name {
  font-size: 24rpx;
  color: #212121;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-section {
  text-align: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #757575;
  display: block;
  margin-bottom: 20rpx;
}

.empty-action {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #E3F2FD;
  color: #2196F3;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.progress-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.progress-item {
  display: flex;
  flex-direction: column;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-name {
  font-size: 26rpx;
  color: #212121;
}

.progress-percent {
  font-size: 26rpx;
  color: #2196F3;
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2196F3 0%, #1976D2 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #212121;
}

.menu-arrow {
  font-size: 28rpx;
  color: #BDBDBD;
}