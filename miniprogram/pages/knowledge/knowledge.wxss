.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #212121;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #757575;
}

.category-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.category-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  min-width: 140rpx;
  flex-shrink: 0;
}

.category-tab.active {
  background: #E3F2FD;
}

.category-tab.active .tab-name {
  color: #2196F3;
  font-weight: 600;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-name {
  font-size: 26rpx;
  color: #757575;
}

.cards-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.knowledge-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #212121;
}

.card-content {
  margin-bottom: 20rpx;
}

.card-preview {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.6;
}

.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.card-action {
  font-size: 26rpx;
  color: #2196F3;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #757575;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 200;
}

.detail-content {
  width: 100%;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #212121;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #757575;
  font-size: 32rpx;
}

.detail-body {
  max-height: 50vh;
  margin-bottom: 30rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #212121;
  line-height: 1.8;
}

.detail-example {
  margin-top: 30rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
}

.example-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2196F3;
  display: block;
  margin-bottom: 12rpx;
}

.example-text {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.6;
}

.detail-action {
  padding: 28rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  border-radius: 16rpx;
  text-align: center;
}

.detail-action text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}