<view class="color-picker-container" wx:if="{{show}}">
  <view class="color-picker-content">
    <view class="picker-header flex-between">
      <text class="picker-title font-medium font-bold text-primary">选择颜色</text>
      <view class="picker-close" bindtap="closePicker">✕</view>
    </view>
    
    <view class="color-grid flex-row">
      <block wx:for="{{colors}}" wx:key="*this">
        <view 
          class="color-item {{selectedColor === item ? 'selected' : ''}}"
          style="background-color: {{item}}"
          bindtap="selectColor"
          data-color="{{item}}">
        </view>
      </block>
    </view>
    
    <view class="custom-color-section">
      <text class="custom-label font-medium text-primary">自定义颜色</text>
      <input 
        class="custom-input"
        type="text"
        placeholder="输入颜色值(如#FF5722)"
        value="{{selectedColor}}"
        bindinput="onColorChange"
      />
    </view>
    
    <view class="preview-section">
      <text class="preview-label font-medium text-primary">当前颜色</text>
      <view class="preview-color" style="background-color: {{selectedColor}}"></view>
    </view>
  </view>
</view>