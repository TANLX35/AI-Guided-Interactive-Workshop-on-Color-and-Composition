/* ── 创作沙盘 · 文艺清新配色 ── */

.sandbox-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8F5F0;
  overflow: hidden;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
}

/* ── 画布区域 ── */
.canvas-section {
  flex: 1;
  padding: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.canvas-wrapper {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(139, 123, 107, 0.1);
}

.main-canvas {
  position: absolute;
  top: 0;
  left: 0;
}

/* ── 参考线 ── */
.guide-lines {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.guide-line {
  position: absolute;
  background-color: rgba(212, 165, 116, 0.3);
}

.guide-thirds .guide-line-vertical {
  width: 1rpx;
  height: 100%;
  background-color: rgba(212, 165, 116, 0.3);
}

.guide-thirds .guide-line-horizontal {
  width: 100%;
  height: 1rpx;
  background-color: rgba(212, 165, 116, 0.3);
}

.guide-thirds .guide-line-1 {
  left: 33.33%;
  top: 0;
}

.guide-thirds .guide-line-2 {
  left: 66.66%;
  top: 0;
}

.guide-thirds .guide-line-horizontal.guide-line-1 {
  top: 33.33%;
  left: 0;
}

.guide-thirds .guide-line-horizontal.guide-line-2 {
  top: 66.66%;
  left: 0;
}

.guide-diagonal .guide-line-diagonal-1 {
  width: 100%;
  height: 1rpx;
  transform: rotate(45deg);
  top: 50%;
  left: 0;
  transform-origin: center;
  background-color: rgba(164, 181, 163, 0.35);
}

.guide-diagonal .guide-line-diagonal-2 {
  width: 100%;
  height: 1rpx;
  transform: rotate(-45deg);
  top: 50%;
  left: 0;
  transform-origin: center;
  background-color: rgba(164, 181, 163, 0.35);
}

.guide-symmetry .guide-line-center {
  width: 1rpx;
  height: 100%;
  left: 50%;
  top: 0;
  background-color: rgba(164, 181, 163, 0.35);
}

/* ── 黄金螺旋 ── */
.golden-rect {
  position: absolute;
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  background-color: rgba(212, 165, 116, 0.04);
}

.golden-spiral-dot {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background-color: #D4A574;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 12rpx rgba(212, 165, 116, 0.4);
}

/* ── 画布元素 ── */
.canvas-element {
  position: absolute;
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 123, 107, 0.15);
  transition: transform 0.1s ease;
}

.triangle-element {
  background-color: transparent !important;
  border-radius: 0 !important;
  box-shadow: none;
}

.canvas-element.selected {
  border: 3rpx solid #D4A574;
  box-shadow: 0 4rpx 20rpx rgba(212, 165, 116, 0.3);
}

.triangle-element.selected {
  border: none;
  box-shadow: 0 0 0 3rpx #D4A574;
}

.canvas-element.dragging {
  opacity: 0.8;
  box-shadow: 0 8rpx 24rpx rgba(139, 123, 107, 0.25);
}

/* 滤镜 */
.filter-blur { filter: blur(3px); }
.filter-grayscale { filter: grayscale(100%); }
.filter-invert { filter: invert(100%); }
.filter-sepia { filter: sepia(100%); }

/* ── 操控手柄 ── */
.element-handles-container {
  position: absolute;
  pointer-events: none;
}

.element-handles {
  position: relative;
  pointer-events: none;
}

.handle {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  background-color: #D4A574;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
  pointer-events: auto;
  box-shadow: 0 2rpx 8rpx rgba(139, 123, 107, 0.2);
}

.handle:active {
  background-color: #C4956B;
  transform: scale(1.2);
}

.handle-e {
  right: -9rpx;
  top: 50%;
  margin-top: -9rpx;
}

.handle-s {
  bottom: -9rpx;
  left: 50%;
  margin-left: -9rpx;
}

.handle-n {
  top: -9rpx;
  left: 50%;
  margin-left: -9rpx;
}

.handle-w {
  left: -9rpx;
  top: 50%;
  margin-top: -9rpx;
}

.handle-center {
  top: 50%;
  left: 50%;
  margin-top: -9rpx;
  margin-left: -9rpx;
  background-color: #A4B5A3;
}

.handle-center:active {
  background-color: #8AA08A;
}

.handle-rotate {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  background-color: #D4A574;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  pointer-events: auto;
  top: -14rpx;
  left: 50%;
  margin-left: -14rpx;
  transform: translateY(-100%);
  box-shadow: 0 2rpx 8rpx rgba(139, 123, 107, 0.2);
}

.handle-rotate:active {
  background-color: #C4956B;
  transform: translateY(-100%) scale(1.2);
}

.handle-rotate::after {
  content: '↻';
  color: #FFFFFF;
  font-size: 16rpx;
  font-weight: bold;
}

/* ── 工具栏 ── */
.toolbar-section {
  padding: 16rpx 20rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #EDE8E2;
}

.toolbar {
  justify-content: space-around;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tool-item:active {
  background-color: #F5F2ED;
  transform: scale(0.94);
}

.tool-icon {
  font-size: 34rpx;
  margin-bottom: 4rpx;
}

.tool-label {
  font-size: 22rpx;
  color: #B5A898;
}

/* ── 参考线选择器 ── */
.guide-line-selector {
  padding: 12rpx 20rpx;
  background-color: #FFFFFF;
  justify-content: space-around;
  gap: 8rpx;
}

.guide-option {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  background-color: #F5F2ED;
  color: #B5A898;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.25s;
}

.guide-option.active {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(139, 123, 107, 0.2);
}

/* ── 滤镜选择器 ── */
.filter-selector {
  padding: 12rpx 20rpx;
  background-color: #FFFFFF;
  justify-content: space-around;
  gap: 8rpx;
  border-top: 1rpx solid #EDE8E2;
}

.filter-option {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  background-color: #F5F2ED;
  color: #B5A898;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.25s;
}

.filter-option.active {
  background: linear-gradient(135deg, #A4B5A3 0%, #8AA08A 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(164, 181, 163, 0.25);
}

/* ── 颜色选择器弹窗 ── */
.color-picker-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(61, 61, 61, 0.4);
  backdrop-filter: blur(4rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.color-picker-content {
  width: 82%;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(139, 123, 107, 0.15);
}

.color-picker-header {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #EDE8E2;
  margin-bottom: 24rpx;
}

.color-picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.color-grid {
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 16rpx;
}

.color-item {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(139, 123, 107, 0.08);
}

.color-item.selected {
  border-color: #8B7B6B;
  transform: scale(1.15);
  box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.2);
}

/* ── 聊天助手内嵌 ── */
.chat-assistant {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 64%;
  height: 60%;
  background-color: #FFFFFF;
  border-radius: 20rpx 0 0 20rpx;
  box-shadow: -4rpx 0 24rpx rgba(139, 123, 107, 0.12);
  display: flex;
  flex-direction: column;
  z-index: 999;
}

.chat-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #EDE8E2;
}

.chat-close {
  font-size: 32rpx;
  color: #B5A898;
  padding: 8rpx;
}

.chat-messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.chat-message {
  margin-bottom: 20rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  line-height: 1.5;
  font-size: 26rpx;
}

.chat-message.user {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
  margin-left: 40rpx;
}

.chat-message.assistant {
  background-color: #F5F2ED;
  color: #3D3D3D;
  margin-right: 40rpx;
}

.chat-input {
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #EDE8E2;
  gap: 12rpx;
}

.chat-text-input {
  flex: 1;
  padding: 14rpx 20rpx;
  background-color: #F8F5F0;
  border: 1rpx solid #EDE8E2;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #3D3D3D;
}

.chat-text-input::placeholder {
  color: #C5BFB6;
}

.chat-send-btn {
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #D4A574 0%, #C4956B 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: none;
}

.chat-send-btn::after {
  border: none;
}

/* ── 底部按钮 ── */
.action-buttons {
  padding: 20rpx;
  justify-content: space-around;
  gap: 20rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #EDE8E2;
}

.action-btn {
  width: 45%;
}

/* ── 加载遮罩 ── */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(61, 61, 61, 0.3);
  backdrop-filter: blur(4rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1001;
}

.loading-content {
  background-color: #FFFFFF;
  padding: 48rpx 60rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(139, 123, 107, 0.15);
}

.loading-text {
  font-size: 28rpx;
  color: #8B7B6B;
}
