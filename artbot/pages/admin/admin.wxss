/* ── 管理后台 · 文艺清新配色 ── */

.admin-container {
  padding: 24rpx;
  background-color: #F8F5F0;
  min-height: 100vh;
}

/* ── 头部 ── */
.admin-header {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.06);
}

.logout-btn {
  padding: 10rpx 24rpx;
  background-color: #F5F2ED;
  border-radius: 20rpx;
  color: #B5A898;
  font-size: 24rpx;
}

/* ── 分区标签 ── */
.section-tabs {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  justify-content: space-around;
  box-shadow: 0 2rpx 12rpx rgba(139, 123, 107, 0.05);
}

.section-tab {
  flex: 1;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #B5A898;
  text-align: center;
  font-weight: 500;
  transition: all 0.25s;
}

.section-tab.active {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(139, 123, 107, 0.2);
}

/* ── 内容区 ── */
.section-content {
  margin-top: 8rpx;
}

.add-btn {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 28rpx;
}

/* ── 列表项 ── */
.items-list {
  margin-top: 8rpx;
}

.item-card {
  margin-bottom: 20rpx;
}

.item-header {
  margin-bottom: 16rpx;
}

.item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.item-actions {
  margin-left: 20rpx;
  display: flex;
  gap: 8rpx;
}

.edit-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #D4A574 0%, #C4956B 100%);
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

.edit-btn::after {
  border: none;
}

.delete-btn {
  padding: 8rpx 20rpx;
  background-color: #FCE8E4;
  color: #D4735E;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

.delete-btn::after {
  border: none;
}

.item-desc {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 26rpx;
  color: #9B9B9B;
}

.item-difficulty,
.item-category {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #B5A898;
}

/* ── 配置卡片 ── */
.config-card {
  margin-bottom: 20rpx;
}

.config-title {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.provider-selector {
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.provider-option {
  flex: 1;
  padding: 12rpx 0;
  border-radius: 20rpx;
  background-color: #F5F2ED;
  font-size: 26rpx;
  color: #B5A898;
  text-align: center;
  font-weight: 500;
  transition: all 0.25s;
}

.provider-option.active {
  background: linear-gradient(135deg, #D4A574 0%, #C4956B 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.25);
}

/* ── 配置字段 ── */
.config-field {
  margin-bottom: 20rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #9B9B9B;
}

.field-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background-color: #F8F5F0;
  border-radius: 14rpx;
  border: 1rpx solid #EDE8E2;
  font-size: 28rpx;
  color: #3D3D3D;
  box-sizing: border-box;
}

.field-input:focus {
  border-color: #D4A574;
  background-color: #FFFCF8;
}

.field-input::placeholder {
  color: #C5BFB6;
}

/* ── 统计网格 ── */
.stats-grid {
  justify-content: space-between;
}

.stat-card {
  width: 45%;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.stat-value {
  margin-bottom: 10rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #8B7B6B;
}

.stat-label {
  font-size: 24rpx;
  color: #B5A898;
}
