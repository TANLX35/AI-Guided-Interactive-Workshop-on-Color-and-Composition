/* ── 设置页 · 文艺清新配色 ── */

.settings-container {
  min-height: 100vh;
  background-color: #F8F5F0;
}

/* ── 头部 ── */
.settings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 20rpx;
  background-color: #FFFFFF;
}

.header-back {
  font-size: 48rpx;
  color: #3D3D3D;
  padding: 10rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.header-placeholder {
  width: 60rpx;
}

/* ── 内容区 ── */
.settings-content {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #B5A898;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.06);
}

/* ── 用户信息 ── */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4A574 0%, #8B7B6B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-right: 20rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 6rpx;
}

.user-id {
  font-size: 24rpx;
  color: #B5A898;
}

.login-prompt {
  font-size: 28rpx;
  color: #9B9B9B;
  margin-bottom: 24rpx;
  display: block;
}

.login-actions {
  display: flex;
  justify-content: center;
}

.action-btn {
  padding: 16rpx 44rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  background-color: #F5F2ED;
  color: #3D3D3D;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
}

.logout-btn {
  width: 100%;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  background-color: #F5F2ED;
  color: #3D3D3D;
  border: none;
}

.logout-btn::after {
  border: none;
}

.logout-btn.danger {
  background-color: #FCE8E4;
  color: #D4735E;
}

/* ── 配置信息 ── */
.config-label {
  font-size: 24rpx;
  color: #B5A898;
  display: block;
  margin-bottom: 6rpx;
}

.config-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.config-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3D3D;
  margin-bottom: 16rpx;
  display: block;
}

/* ── 服务商选择 ── */
.provider-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.provider-item {
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  background-color: #F5F2ED;
  border: 2rpx solid transparent;
  min-width: 200rpx;
  transition: all 0.2s;
}

.provider-item.active {
  border-color: #D4A574;
  background-color: #FFFCF6;
}

.provider-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3D3D;
  display: block;
}

.provider-desc {
  font-size: 20rpx;
  color: #B5A898;
  margin-top: 6rpx;
  display: block;
}

/* ── 输入框 ── */
.config-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1rpx solid #EDE8E2;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #3D3D3D;
  background-color: #F8F5F0;
  box-sizing: border-box;
}

.config-input:focus {
  border-color: #D4A574;
  background-color: #FFFCF8;
}

.config-input::placeholder {
  color: #C5BFB6;
}

/* ── 开关 ── */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.setting-label {
  font-size: 28rpx;
  color: #3D3D3D;
}

.setting-switch {
  width: 80rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #D5CFC7;
  position: relative;
  transition: background-color 0.3s;
}

.setting-switch.on {
  background: linear-gradient(135deg, #A4B5A3 0%, #8AA08A 100%);
}

.switch-circle {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  transition: left 0.3s;
  box-shadow: 0 2rpx 6rpx rgba(139, 123, 107, 0.15);
}

.setting-switch.on .switch-circle {
  left: 43rpx;
}

/* ── 快捷菜单 ── */
.menu-list {
  display: flex;
  gap: 20rpx;
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F2ED;
  border-radius: 16rpx;
}

.menu-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.menu-text {
  font-size: 24rpx;
  color: #9B9B9B;
}

/* ── 弹窗 ── */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(61, 61, 61, 0.4);
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(139, 123, 107, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #EDE8E2;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.modal-close {
  font-size: 36rpx;
  color: #B5A898;
  padding: 8rpx;
  width: 56rpx;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #9B9B9B;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #EDE8E2;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #3D3D3D;
  background-color: #F8F5F0;
  box-sizing: border-box;
  line-height: 80rpx;
}

.form-input:focus {
  border-color: #D4A574;
  background-color: #FFFCF8;
}

.form-tip {
  font-size: 22rpx;
  color: #B5A898;
  text-align: center;
  margin-top: 10rpx;
}

.modal-footer {
  border-top: 1rpx solid #EDE8E2;
}

.modal-footer-row {
  display: flex;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background-color: transparent;
  line-height: 1.5;
}

.modal-btn::after {
  border: none;
}

.modal-btn.full {
  color: #8B7B6B;
  font-weight: 600;
}

.modal-btn.primary {
  color: #8B7B6B;
  font-weight: 600;
  border-left: 1rpx solid #EDE8E2;
}

.modal-btn.secondary {
  color: #B5A898;
}
