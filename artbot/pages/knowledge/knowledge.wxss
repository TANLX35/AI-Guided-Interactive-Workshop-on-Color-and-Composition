/* ── 知识理论 · 文艺清新配色 ── */

.knowledge-container {
  padding: 24rpx;
  background-color: #F8F5F0;
  min-height: 100vh;
}

/* ── 搜索 ── */
.search-section {
  margin-bottom: 20rpx;
  display: flex;
  align-items: stretch;
}

.search-input {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 28rpx;
  border: 1rpx solid #EDE8E2;
  font-size: 28rpx;
  color: #3D3D3D;
  line-height: 48rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 123, 107, 0.04);
  box-sizing: border-box;
}

.search-input::placeholder {
  color: #C5BFB6;
}

/* ── 分类标签 ── */
.category-section {
  margin-bottom: 20rpx;
}

.category-tabs {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
  flex-wrap: wrap;
  box-shadow: 0 2rpx 12rpx rgba(139, 123, 107, 0.05);
}

.category-tab {
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  margin: 6rpx;
  font-size: 26rpx;
  color: #B5A898;
  font-weight: 500;
  transition: all 0.25s;
}

.category-tab.active {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(139, 123, 107, 0.2);
}

/* ── 知识卡片列表 ── */
.cards-list {
  margin-top: 8rpx;
}

.card-item {
  margin-bottom: 20rpx;
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.card-category {
  padding: 6rpx 16rpx;
  background-color: #F5F2ED;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #8B7B6B;
}

.card-content {
  line-height: 1.7;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #9B9B9B;
}

.card-actions {
  padding-top: 16rpx;
  border-top: 1rpx solid #EDE8E2;
}

.card-btn {
  padding: 10rpx 32rpx;
  font-size: 24rpx;
}

/* ── 空状态 ── */
.empty-section {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B5A898;
}
