/* ── 全局样式 · 文艺清新配色 ── */
page {
  background-color: #F8F5F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Noto Serif SC', 'Source Han Serif SC', 'Microsoft YaHei', serif;
  color: #3D3D3D;
}

/* ── 通用容器 ── */
.container { padding: 24rpx; }

/* ── 颜色变量 ── */
.primary-color    { color: #8B7B6B; }
.accent-color     { color: #D4A574; }
.green-color      { color: #A4B5A3; }
.warning-color    { color: #E8B86D; }
.error-color      { color: #D4735E; }

.text-primary     { color: #3D3D3D; }
.text-secondary   { color: #9B9B9B; }
.text-muted       { color: #C5BFB6; }

/* ── 背景 ── */
.bg-primary       { background-color: #8B7B6B; }
.bg-accent        { background-color: #D4A574; }
.bg-green         { background-color: #A4B5A3; }
.bg-warm          { background-color: #F8F5F0; }
.bg-white         { background-color: #FFFFFF; }

/* ── 卡片 ── */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.06);
}

/* ── 按钮 ── */
.btn-primary {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
}
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: #8B7B6B;
  border: 2rpx solid #8B7B6B;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
}
.btn-outline::after { border: none; }

.btn-accent {
  background: linear-gradient(135deg, #D4A574 0%, #C4956B 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
}
.btn-accent::after { border: none; }

.btn-secondary {
  background: #F0EDE8;
  color: #8B7B6B;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
}
.btn-secondary::after { border: none; }

/* ── 布局 ── */
.flex-row       { display: flex; flex-direction: row; }
.flex-column    { display: flex; flex-direction: column; }
.flex-center    { display: flex; justify-content: center; align-items: center; }
.flex-between   { display: flex; justify-content: space-between; align-items: center; }
.flex-wrap      { display: flex; flex-wrap: wrap; }

/* ── 文字 ── */
.text-center  { text-align: center; }
.text-left    { text-align: left; }
.text-right   { text-align: right; }
.font-bold    { font-weight: 600; }
.font-large   { font-size: 36rpx; }
.font-medium  { font-size: 28rpx; }
.font-small   { font-size: 24rpx; }
.font-xs      { font-size: 20rpx; }

/* ── 间距 ── */
.margin-top     { margin-top: 20rpx; }
.margin-bottom  { margin-bottom: 20rpx; }
.margin-left    { margin-left: 20rpx; }
.margin-right   { margin-right: 20rpx; }
.padding-all    { padding: 20rpx; }

/* ── 圆角 / 阴影 ── */
.radius-sm   { border-radius: 8rpx; }
.radius-md   { border-radius: 16rpx; }
.radius-lg   { border-radius: 24rpx; }
.radius-full { border-radius: 999rpx; }
.shadow-sm   { box-shadow: 0 2rpx 12rpx rgba(139, 123, 107, 0.06); }
.shadow-md   { box-shadow: 0 4rpx 20rpx rgba(139, 123, 107, 0.10); }

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: #EDE8E2;
  margin: 20rpx 0;
}

/* ── 标签 ── */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #F0EDE8;
  color: #8B7B6B;
}
.tag-accent { background: #FDF3E8; color: #D4A574; }
.tag-green  { background: #EEF2EE; color: #7A8F7A; }

/* ── 安全区 ── */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ── 渐变 ── */
.gradient-primary {
  background: linear-gradient(135deg, #8B7B6B 0%, #A49383 100%);
}
.gradient-accent {
  background: linear-gradient(135deg, #D4A574 0%, #C4956B 100%);
}
.gradient-green {
  background: linear-gradient(135deg, #A4B5A3 0%, #8AA08A 100%);
}

/* ── 进度条通用 ── */
.progress-track {
  height: 10rpx;
  background-color: #EDE8E2;
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill-primary {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #A4B5A3 0%, #8B7B6B 100%);
}

/* ── 输入框通用 ── */
.input-field {
  width: 100%;
  padding: 20rpx 24rpx;
  background-color: #F8F5F0;
  border: 1rpx solid #EDE8E2;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #3D3D3D;
  box-sizing: border-box;
}
.input-field:focus {
  border-color: #D4A574;
  background-color: #FFFCF8;
}
.input-field::placeholder {
  color: #C5BFB6;
}

/* ── 难度标签 ── */
.difficulty-easy   { background: #EEF2EE; color: #7A8F7A; }
.difficulty-medium { background: #FDF3E8; color: #D4A574; }
.difficulty-hard   { background: #FCE8E4; color: #D4735E; }

/* ── 遮罩层 ── */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(61, 61, 61, 0.4);
  backdrop-filter: blur(4rpx);
  z-index: 1000;
}

/* ── 过渡动画 ── */
.transition {
  transition: all 0.25s ease;
}

/* ── 选中状态 ── */
.selected-primary {
  border-color: #8B7B6B !important;
  box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.2);
}

/* ── 水平滚动容器 ── */
.scroll-x {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
